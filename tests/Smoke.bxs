template = new models.TSPLTemplate()
	.dimensions( 576, "auto" )
	.gap( 0 )
	.moveTo( 0, 20 )
	.anchor( "center" )
	.text( "Order {orderNumber}", "3" )
	.advance( 12 )
	.qrCode( "{trackingCode}", 6 )
	.print();

commands = template.write(
	{
		orderNumber  : 1042,
		trackingCode : "ZX-1042-OK"
	},
	new models.TSPLStringWriter()
);

for ( command in commands ) {
	println( command );
}
